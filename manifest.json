{
  "manifest_version": 3,
  "name": "TikTok Interaction Fixer",
  "version": "1.0.0",
  "description": "Bypasses adblocker blocking on TikTok telemetry to resolve interaction issues.",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "declarativeNetRequest"
  ],
  "host_permissions": [
    "https://*.tiktok.com/*",
    "https://*.byteoversea.com/*",
    "https://*.ibytedtos.com/*",
    "https://*.tiktokv.com/*"
  ],
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "ruleset_1",
        "enabled": true,
        "path": "rules.json"
      }
    ]
  }
}
